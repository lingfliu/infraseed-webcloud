# Copy to .env and adjust. Used by docker compose and by apps when run locally.

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=webcloud
MYSQL_USER=app
MYSQL_PASSWORD=app

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# MinIO
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=webcloud
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Nacos (when using discovery)
NACOS_SERVER=localhost:8848

# App ports (for local runs)
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
DATA_SERVICE_PORT=8082
SYSTEM_SERVICE_PORT=8083
